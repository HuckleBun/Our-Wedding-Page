{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev (opens browser)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/dev.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
